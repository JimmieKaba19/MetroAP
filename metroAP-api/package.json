{
  "name": "nairobi-transit-api",
  "version": "0.1.0",
  "description": "MetroAP backend — real-time bus tracking API",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":        "tsx watch src/server.ts",
    "build":      "tsc",
    "start":      "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:seed":    "tsx prisma/seed.ts",
    "db:studio":  "prisma studio",
    "db:reset":   "prisma migrate reset --force && tsx prisma/seed.ts",
    "typecheck":  "tsc --noEmit",
    "lint":       "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors":      "^9.0.1",
    "@fastify/helmet":    "^11.1.1",
    "@fastify/jwt":       "^8.0.1",
    "@fastify/rate-limit":"^9.1.0",
    "@prisma/client":     "^5.14.0",
    "bcrypt":             "^5.1.1",
    "firebase-admin":     "^12.2.0",
    "fastify":            "^4.27.0",
    "ioredis":            "^5.4.1",
    "socket.io":          "^4.7.5",
    "zod":                "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt":      "^5.0.2",
    "@types/node":        "^20.14.2",
    "prisma":             "^5.14.0",
    "tsx":                "^4.15.6",
    "typescript":         "^5.4.5"
  }
}
